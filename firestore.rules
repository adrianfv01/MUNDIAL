rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    function esDueno(uid) {
      return autenticado() && request.auth.uid == uid;
    }

    function idContieneUid(id) {
      return autenticado() && request.auth.uid in id.split('_');
    }

    function ordenar(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function sonAmigos(uid) {
      return autenticado() && exists(
        /databases/$(database)/documents/amistades/$(ordenar(request.auth.uid, uid))
      );
    }

    match /equipos/{codigo} {
      allow read: if true;
      allow write: if false;
    }

    match /catalogo/{stickerId} {
      allow read: if true;
      allow write: if false;
    }

    match /usuarios/{uid} {
      allow read: if true;
      allow create: if esDueno(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.username is string
                    && request.resource.data.displayName is string;
      allow update: if esDueno(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.username == resource.data.username;
      allow delete: if esDueno(uid);
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if autenticado()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if autenticado()
                    && resource.data.uid == request.auth.uid;
    }

    match /usuarios/{uid}/coleccion/{stickerId} {
      allow read: if esDueno(uid) || sonAmigos(uid);

      // Cambio de un amigo: solo permitido si el delta absoluto es 1.
      // Esto restringe el dano potencial a una unidad por click.
      function deltaAmigoValido() {
        let nueva = request.resource.data.cantidad;
        let anterior = resource == null ? 0 : resource.data.cantidad;
        return nueva is number
               && nueva >= 0
               && nueva <= 999
               && (nueva == anterior + 1 || nueva == anterior - 1);
      }

      allow create, update: if (
        esDueno(uid)
        && request.resource.data.cantidad is number
        && request.resource.data.cantidad >= 0
        && request.resource.data.cantidad <= 999
      ) || (
        sonAmigos(uid) && deltaAmigoValido()
      );
      allow delete: if esDueno(uid);
    }

    match /solicitudesAmistad/{id} {
      allow get: if autenticado() && (
        resource == null
          ? idContieneUid(id)
          : (request.auth.uid == resource.data.de
             || request.auth.uid == resource.data.para)
      );
      allow list: if autenticado()
                  && (request.auth.uid == resource.data.de
                      || request.auth.uid == resource.data.para);
      allow create: if autenticado()
                    && request.resource.data.de == request.auth.uid
                    && request.resource.data.estado == 'pendiente'
                    && request.resource.data.de != request.resource.data.para;
      allow update: if autenticado()
                    && request.auth.uid == resource.data.para
                    && request.resource.data.estado in ['aceptada', 'rechazada']
                    && request.resource.data.de == resource.data.de
                    && request.resource.data.para == resource.data.para;
      allow delete: if autenticado()
                    && (request.auth.uid == resource.data.de
                        || request.auth.uid == resource.data.para);
    }

    match /amistades/{id} {
      allow get: if autenticado() && (
        resource == null
          ? idContieneUid(id)
          : request.auth.uid in resource.data.usuarios
      );
      allow list: if autenticado()
                  && request.auth.uid in resource.data.usuarios;
      allow create: if autenticado()
                    && request.auth.uid in request.resource.data.usuarios
                    && request.resource.data.usuarios.size() == 2
                    && request.resource.data.usuarios[0] is string
                    && request.resource.data.usuarios[1] is string
                    && request.resource.data.usuarios[0] < request.resource.data.usuarios[1]
                    && id == request.resource.data.usuarios[0] + '_' + request.resource.data.usuarios[1];
      allow update: if autenticado()
                    && resource.data.usuarios == request.resource.data.usuarios;
      allow delete: if autenticado()
                    && request.auth.uid in resource.data.usuarios;
    }
  }
}
